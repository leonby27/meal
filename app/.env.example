# Copy this file to .env and fill in real values. .env is gitignored.
# Sourced by ../run.sh and ../build-ipa.sh, passed to Flutter via --dart-define.

# AppsFlyer SDK dev key. Find in AppsFlyer dashboard → App Settings → SDK keys.
# Treat as semi-secret: it lands in the app binary, but a leaked key lets
# anyone send junk events into your AppsFlyer dashboard.
APPSFLYER_DEV_KEY=
