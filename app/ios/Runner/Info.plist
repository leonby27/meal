	<!--
	  SKAdNetworkItems: the ad networks this app accepts SKAN install attribution
	  from. Without these, even paid ads from TikTok won't show up as attributed
	  installs for users who declined ATT (~70% of iOS). TikTok IDs are the only
	  ones strictly required for the current campaign; the rest are pre-listed
	  so adding Meta / Google / Snap / etc. later does not require a new App
	  Store submission. Apple ignores IDs from networks we don't actually use.
	-->
	<key>SKAdNetworkItems</key>
	<array>
		<!-- TikTok / ByteDance / Pangle -->
		<dict><key>SKAdNetworkIdentifier</key><string>238da6jt44.skadnetwork</string></dict>
		<dict><key>SKAdNetworkIdentifier</key><string>22mmun2rn5.skadnetwork</string></dict>
		<!-- Meta (Facebook / Instagram Audience Network) -->
		<dict><key>SKAdNetworkIdentifier</key><string>v9wttpbfk9.skadnetwork</string></dict>
		<dict><key>SKAdNetworkIdentifier</key><string>n38lu8286q.skadnetwork</string></dict>
		<!-- Google (AdMob / Universal App Campaigns) -->
