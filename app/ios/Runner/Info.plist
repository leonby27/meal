	<!--
	  Lets iOS forward SKAN postbacks to AppsFlyer's endpoint (AppsFlyer then
	  fans them out to TikTok and any other partners). Without this, Apple
	  sends postbacks only to the ad network that won the auction — AppsFlyer
	  never sees them, and the AppsFlyer dashboard / TikTok reports stay empty.
	-->
	<key>NSAdvertisingAttributionReportEndpoint</key>
	<string>https://appsflyer-skadnetwork.com</string>
