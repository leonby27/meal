# PostgreSQL (Timeweb Cloud)
# Формат: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql+asyncpg://gen_user:PASSWORD@HOST:5432/default_db
DATABASE_SSL=true

# Для локальной разработки без PostgreSQL:
# DATABASE_URL=sqlite+aiosqlite:///./mealtracker.db
# DATABASE_SSL=false

SECRET_KEY=your-secret-key-change-me

# Google OAuth (Web client ID from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

TIMEWEB_AI_AGENT_ID=your-agent-id
TIMEWEB_AI_TOKEN=your-timeweb-token
